{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"custom": false,
			"customDuotone": false,
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"palette": [
				{
					"name": "Base",
					"slug": "base",
					"color": "#ffffff"
				},
				{
					"name": "Contrast",
					"slug": "contrast",
					"color": "#111827"
				},
				{
					"name": "Muted",
					"slug": "muted",
					"color": "#6b7280"
				},
				{
					"name": "Surface",
					"slug": "surface",
					"color": "#f3f4f6"
				},
				{
					"name": "Primary",
					"slug": "primary",
					"color": "#2563eb"
				},
				{
					"name": "Primary Contrast",
					"slug": "primary-contrast",
					"color": "#ffffff"
				}
			]
		},
		"custom": {
			"border": {
				"radius": {
					"small": "4px",
					"medium": "8px",
					"large": "16px"
				}
			},
			"lineHeight": {
				"body": "1.65",
				"heading": "1.2"
			}
		},
		"layout": {
			"contentSize": "720px",
			"wideSize": "1120px"
		},
		"spacing": {
			"customSpacingSize": false,
			"defaultSpacingSizes": false,
			"spacingScale": {
				"operator": "*",
				"increment": 1.5,
				"steps": 0,
				"mediumStep": 1.5,
				"unit": "rem"
			},
			"spacingSizes": [
				{
					"name": "2XS",
					"slug": "20",
					"size": "0.5rem"
				},
				{
					"name": "XS",
					"slug": "30",
					"size": "0.75rem"
				},
				{
					"name": "S",
					"slug": "40",
					"size": "1rem"
				},
				{
					"name": "M",
					"slug": "50",
					"size": "1.5rem"
				},
				{
					"name": "L",
					"slug": "60",
					"size": "2rem"
				},
				{
					"name": "XL",
					"slug": "70",
					"size": "3rem"
				},
				{
					"name": "2XL",
					"slug": "80",
					"size": "4.5rem"
				}
			],
			"units": [
				"px",
				"rem",
				"em",
				"%",
				"vh",
				"vw"
			]
		},
		"typography": {
			"customFontSize": false,
			"defaultFontSizes": false,
			"dropCap": false,
			"fontFamilies": [
				{
					"name": "System Sans",
					"slug": "system-sans",
					"fontFamily": "-apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Oxygen-Sans, Ubuntu, Cantarell, \"Helvetica Neue\", sans-serif"
				}
			],
			"fontSizes": [
				{
					"name": "Small",
					"slug": "small",
					"size": "0.875rem"
				},
				{
					"name": "Medium",
					"slug": "medium",
					"size": "1rem"
				},
				{
					"name": "Large",
					"slug": "large",
					"size": "1.25rem"
				},
				{
					"name": "XL",
					"slug": "x-large",
					"size": "1.75rem"
				},
				{
					"name": "2XL",
					"slug": "xx-large",
					"size": "2.5rem"
				}
			]
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--contrast)"
		},
		"elements": {
			"button": {
				"border": {
					"radius": "4px"
				},
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--primary-contrast)"
				},
				"spacing": {
					"padding": {
						"bottom": "0.75rem",
						"left": "1rem",
						"right": "1rem",
						"top": "0.75rem"
					}
				},
				"typography": {
					"fontWeight": "600"
				}
			},
			"heading": {
				"typography": {
					"fontWeight": "700",
					"lineHeight": "var(--wp--custom--line-height--heading)"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				}
			}
		},
		"spacing": {
			"blockGap": "1.5rem",
			"padding": {
				"left": "var(--wp--preset--spacing--40)",
				"right": "var(--wp--preset--spacing--40)"
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--system-sans)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "var(--wp--custom--line-height--body)"
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Header"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Footer"
		}
	]
}

